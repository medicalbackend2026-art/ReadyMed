# ReadyMD Backend Environment Variables
# Copy this file to .env and fill in the values

PORT=5000

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=readymed-5b855
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@readymed-5b855.iam.gserviceaccount.com
